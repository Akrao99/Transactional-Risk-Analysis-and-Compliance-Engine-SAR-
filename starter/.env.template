# Environment Variables for SAR Processing System
# Copy this file to .env and fill in your actual values

# OpenAI API (or compatible endpoint)
OPENAI_API_KEY=your-api-key-here
# Optional: custom base URL (e.g. for a proxy or alternate provider)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model Configuration (Optional - defaults are provided)
# OPENAI_MODEL=gpt-4
# OPENAI_TEMPERATURE=0.3

# Development Settings
# DEBUG=True
# LOG_LEVEL=INFO

# File Paths (Optional - defaults are provided)
# AUDIT_LOG_FILE=sar_audit.jsonl
# SAR_OUTPUT_DIR=outputs/filed_sars
